# Copy this file to .env and fill in your Supabase project credentials.
# Create a free project at https://supabase.com → Project Settings → API.

# The "Project URL" — looks like https://abcdefgh.supabase.co
SUPABASE_URL=

# The service_role key (NOT the anon key). Only used server-side by the seed
# script, never shipped to the browser. Treat it like a password.
SUPABASE_SERVICE_KEY=

# Long random string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# WebAuthn relying-party config. For local dev, the defaults
#   RP_ID=localhost  ORIGIN=http://localhost:3000  RP_NAME="creature TCG"
# work automatically. In production set these explicitly:
#   RP_ID=creature.example.com
#   ORIGIN=https://creature.example.com
RP_ID=
RP_NAME=
ORIGIN=

# --- Card art generation (scripts/generate-art.js, manual-run only) ---
# Pick a provider, set its key. Default provider is "fal".
#   IMAGE_PROVIDER=google|fal|replicate|openai
IMAGE_PROVIDER=google
# Google Imagen (AI Studio key from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=
# Optional: imagen-3.0-generate-002 (default) or imagen-4.0-generate-001
GOOGLE_IMAGE_MODEL=
# Other providers (only if you use them):
# FAL_KEY=
# REPLICATE_API_TOKEN=
# REPLICATE_MODEL=owner/name:version
# OPENAI_API_KEY=
